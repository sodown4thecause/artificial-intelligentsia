{
  "name": "creature-os",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Creature — AI-Native Work Operating System (Vercel Eve / AI SDK 7 / Native SDK / Mnemosyne)",
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "typecheck": "node ./node_modules/typescript/bin/tsc -p tsconfig.json --noEmit",
    "test": "tsx scripts/run-test-suite.ts all",
    "test:unit": "tsx scripts/run-test-suite.ts unit",
    "test:contract": "tsx scripts/run-test-suite.ts contract",
    "test:eval": "tsx scripts/run-test-suite.ts eval",
    "test:e2e": "tsx scripts/run-test-suite.ts e2e",
    "test:redteam": "tsx scripts/run-test-suite.ts redteam",
    "verify:platform-flows": "tsx scripts/verify-platform-flows.ts",
    "verify:coverage": "tsx scripts/verify-coverage.ts",
    "native:build": "cd native/zig && zig build",
    "native:test": "cd native/zig && zig build test",
    "desktop:check": "native check apps/desktop-native",
    "desktop:build": "native build apps/desktop-native",
    "desktop:package:windows": "cd apps/desktop-native && native package --target windows --output package/windows",
    "desktop:smoke:windows": "tsx scripts/desktop-package-smoke.ts",
    "lint": "echo 'lint placeholder'"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^1.0.0",
    "ai": "^5.0.0",
    "koffi": "^2.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@braintrust/core": "^0.0.95",
    "@native-sdk/cli": "0.5.4",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0",
    "zod": "^3.24.0"
  }
}
