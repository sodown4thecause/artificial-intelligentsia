      "html": "<link data-kid=\"1\" data-name=\"google fonts and tabler icons stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" rel=\"stylesheet\"/>\n<style>\n    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap');\n\n  :root {\n    --color-abyss: #060B19;\n    --color-active: #00FFBF;\n    --color-mid: #1A2E44;\n    --radius-glass: 1.5rem;\n    --shadow-depth: 0 16px 48px rgba(0, 0, 0, 0.4);\n    --blur-glass: 40px;\n  }\n\n  body {\n    margin: 0;\n    padding: 0;\n    overflow: hidden;\n    background: var(--color-abyss);\n    font-family: 'Inter', sans-serif;\n    color: white;\n  }\n\n  .glass-panel {\n    background: rgba(26, 46, 68, 0.45);\n    backdrop-filter: blur(var(--blur-glass));\n    border: 1px solid rgba(255, 255, 255, 0.12);\n    border-radius: var(--radius-glass);\n    box-shadow: var(--shadow-depth);\n  }\n\n  .glass-highlight {\n    position: relative;\n  }\n  .glass-highlight::before {\n    content: '';\n    position: absolute;\n    inset: 0;\n    border-radius: var(--radius-glass);\n    border: 1px solid rgba(255, 255, 255, 0.08);\n    pointer-events: none;\n  }\n\n  .ai-pulse {\n    animation: ai-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;\n  }\n\n  @keyframes ai-pulse {\n    0%, 100% {\n      opacity: 1;\n      transform: scale(1);\n      box-shadow: 0 0 12px rgba(0, 255, 191, 0.5);\n    }\n    50% {\n      opacity: 0.7;\n      transform: scale(0.92);\n      box-shadow: 0 0 20px rgba(0, 255, 191, 0.8);\n    }\n  }\n\n  .dock-item {\n    transition: transform 0.2s cubic-bezier(0.2, 0, 0, 1);\n  }\n  .dock-item:hover {\n    transform: translateY(-8px) scale(1.1);\n  }\n\n  .dynamic-island {\n    transition: all 0.4s cubic-bezier(0.2, 0, 0, 1);\n  }\n  .dynamic-island:hover {\n    width: 240px;\n    background: rgba(26, 46, 68, 0.8);\n  }\n\n  .scrollbar-hidden::-webkit-scrollbar {\n    display: none;\n  }\n</style>\n<div class=\"relative w-full h-screen\" data-kid=\"2\" data-name=\"app layout container\">\n    <!-- Full-bleed Video Background -->\n    <video autoplay=\"\" class=\"absolute inset-0 w-full h-full object-cover pointer-events-none\" data-kid=\"2-1\" data-name=\"full-bleed video background\" loop=\"\" muted=\"\" playsinline=\"\" preload=\"metadata\" src=\"https://kombai-assets.b-cdn.net/generated_assets/59726786-1fa2-482b-9f3b-ff975cc7c7f7/c713d6ec3a2a4786b5cba11cdd965760.mp4\">\n    </video>\n    <!-- Ambient Light Overlays -->\n    <div class=\"absolute top-[-20%] left-[-10%] w-[60%] h-[60%] bg-[var(--color-active)]/5 blur-[160px] rounded-full pointer-events-none\" data-kid=\"2-2\" data-name=\"ambient light top glow\">\n    </div>\n    <div class=\"absolute bottom-[-10%] right-[-5%] w-[50%] h-[50%] bg-[#FF00FF]/5 blur-[140px] rounded-full pointer-events-none\" data-kid=\"2-3\" data-name=\"ambient light bottom glow\">\n    </div>\n    <!-- Top Status Bar -->\n    <header class=\"absolute top-0 w-full h-12 flex items-center justify-between px-6 z-50\" data-kid=\"2-4\" data-name=\"top status bar\">\n        <div class=\"flex items-center gap-4 text-[13px] font-medium text-white/80\" data-kid=\"2-4-1\" data-name=\"system menu items container\">\n            <i class=\"ti ti-apple text-lg\" data-kid=\"2-4-1-1\" data-name=\"apple logo icon\">\n            </i>\n            <span data-kid=\"2-4-1-2\" data-name=\"creature app name\">\n                Creature\n            </span>\n            <span class=\"text-white/40\" data-kid=\"2-4-1-3\" data-name=\"file menu item\">\n                File\n            </span>\n            <span class=\"text-white/40\" data-kid=\"2-4-1-4\" data-name=\"edit menu item\">\n                Edit\n            </span>\n            <span class=\"text-white/40\" data-kid=\"2-4-1-5\" data-name=\"view menu item\">\n                View\n            </span>\n        </div>\n        <!-- Dynamic Island - AI Governor -->\n        <div class=\"dynamic-island h-8 w-44 bg-black/40 backdrop-blur-xl rounded-full flex items-center justify-center gap-3 px-4 border border-white/5 cursor-pointer shadow-lg\" data-kid=\"2-4-2\" data-name=\"dynamic island status indicator\">\n            <div class=\"w-2 h-2 bg-[var(--color-active)] rounded-full ai-pulse\" data-kid=\"2-4-2-1\" data-name=\"active ai pulse indicator\">\n            </div>\n            <span class=\"text-[11px] font-bold tracking-widest text-white/80 uppercase\" data-kid=\"2-4-2-2\" data-name=\"governor status text\">\n                Governor Active\n            </span>\n        </div>\n        <div class=\"flex items-center gap-4 text-[13px] font-medium text-white/80\" data-kid=\"2-4-3\" data-name=\"system connectivity and time container\">\n            <i class=\"ti ti-wifi\" data-kid=\"2-4-3-1\" data-name=\"wifi icon\">\n            </i>\n            <i class=\"ti ti-battery-4\" data-kid=\"2-4-3-2\" data-name=\"battery level icon\">\n            </i>\n            <span class=\"font-mono\" data-dynamic=\"true\" data-kid=\"2-4-3-3\" data-name=\"system time text\" data-reason=\"text updated by system clock\">\n                21:03\n            </span>\n        </div>\n    </header>\n    <!-- Main Go Agent Command Palette (Floating Center) -->\n    <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-xl z-50\" data-kid=\"2-5\" data-name=\"command palette container\">\n        <div class=\"glass-panel glass-highlight p-6 flex flex-col gap-4 border-[1.5px] border-[var(--color-active)]/20 shadow-[0_0_30px_rgba(0,255,191,0.05)]\" data-kid=\"2-5-1\" data-name=\"command palette card\">\n            <div class=\"flex items-center gap-4\" data-kid=\"2-5-1-1\" data-name=\"search bar area\">\n                <i class=\"ti ti-search text-[var(--color-active)] text-2xl\" data-kid=\"2-5-1-1-1\" data-name=\"search icon\">\n                </i>\n                <input class=\"bg-transparent border-none outline-none text-xl w-full text-white placeholder:text-white/20\" data-kid=\"2-5-1-1-2\" data-name=\"command input field\" placeholder=\"Ask Creature...\" type=\"text\"/>\n                <div class=\"flex items-center gap-1.5 bg-white/5 px-2 py-1 rounded border border-white/10\" data-kid=\"2-5-1-1-3\" data-name=\"keyboard shortcut indicator\">\n                    <span class=\"text-[10px] text-white/40 font-bold tracking-tighter\" data-kid=\"2-5-1-1-3-1\" data-name=\"keyboard shortcut cmd\">\n                        CMD\n                    </span>\n                    <span class=\"text-[10px] text-white/40 font-bold tracking-tighter\" data-kid=\"2-5-1-1-3-2\" data-name=\"keyboard shortcut key\">\n                        K\n                    </span>\n                </div>\n            </div>\n            <!-- Suggestions Feed -->\n            <div class=\"mt-4 flex flex-col gap-2 border-t border-white/5 pt-4\" data-kid=\"2-5-1-2\" data-name=\"suggestions feed\">\n                <div class=\"flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 cursor-pointer transition-colors group\" data-kid=\"2-5-1-2-1\" data-name=\"suggestion email item\">\n                    <div class=\"w-8 h-8 rounded-md bg-[var(--color-active)]/10 flex items-center justify-center border border-[var(--color-active)]/20\" data-kid=\"2-5-1-2-1-1\" data-name=\"suggestion email icon wrapper\">\n                        <i class=\"ti ti-mail text-[var(--color-active)]\" data-kid=\"2-5-1-2-1-1-1\" data-name=\"mail icon\">\n                        </i>\n                    </div>\n                    <div data-kid=\"2-5-1-2-1-2\" data-name=\"suggestion email text\">\n                        <p class=\"text-sm font-medium\" data-kid=\"2-5-1-2-1-2-1\" data-name=\"suggestion email title\">\n                            Summarize unread emails from HR\n                        </p>\n                        <p class=\"text-[11px] text-white/30\" data-kid=\"2-5-1-2-1-2-2\" data-name=\"suggestion email subtitle\">\n                            Action Shadowing enabled\n                        </p>\n                    </div>\n                    <i class=\"ti ti-chevron-right ml-auto text-white/20 group-hover:text-active transition-colors\" data-kid=\"2-5-1-2-1-3\" data-name=\"chevron right icon\">\n                    </i>\n                </div>\n                <div class=\"flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-white/5 cursor-pointer transition-colors group\" data-kid=\"2-5-1-2-2\" data-name=\"suggestion calendar item\">\n                    <div class=\"w-8 h-8 rounded-md bg-white/5 flex items-center justify-center border border-white/10\" data-kid=\"2-5-1-2-2-1\" data-name=\"suggestion calendar icon wrapper\">\n                        <i class=\"ti ti-calendar text-white/40\" data-kid=\"2-5-1-2-2-1-1\" data-name=\"calendar icon\">\n                        </i>\n                    </div>\n                    <div data-kid=\"2-5-1-2-2-2\" data-name=\"suggestion calendar text\">\n                        <p class=\"text-sm font-medium\" data-kid=\"2-5-1-2-2-2-1\" data-name=\"suggestion calendar title\">\n                            Schedule prep for next design review\n                        </p>\n                        <p class=\"text-[11px] text-white/30\" data-kid=\"2-5-1-2-2-2-2\" data-name=\"suggestion calendar subtitle\">\n                            Checks Availability via G-Cal\n                        </p>\n                    </div>\n                    <i class=\"ti ti-chevron-right ml-auto text-white/20 group-hover:text-active transition-colors\" data-kid=\"2-5-1-2-2-3\" data-name=\"chevron right icon\">\n                    </i>\n                </div>\n            </div>\n        </div>\n    </div>\n    <!-- Bottom App Dock -->\n    <footer class=\"absolute bottom-8 left-1/2 -translate-x-1/2 z-50\" data-kid=\"2-6\" data-name=\"app dock\">\n        <div class=\"glass-panel glass-highlight px-3 py-2.5 flex items-end gap-2 border-white/10\" data-kid=\"2-6-1\" data-name=\"dock container\">\n            <!-- App Icons -->\n            <div class=\"dock-item w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center border border-white/10 cursor-pointer backdrop-blur-md\" data-kid=\"2-6-1-1\" data-name=\"mail app icon\">\n                <i class=\"ti ti-mail text-2xl text-white/80\" data-kid=\"2-6-1-1-1\" data-name=\"mail icon\">\n                </i>\n            </div>\n            <div class=\"dock-item w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center border border-white/10 cursor-pointer backdrop-blur-md\" data-kid=\"2-6-1-2\" data-name=\"file explorer app icon\">\n                <i class=\"ti ti-file-text text-2xl text-white/80\" data-kid=\"2-6-1-2-1\" data-name=\"file text icon\">\n                </i>\n            </div>\n            <div class=\"dock-item w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center border border-white/10 cursor-pointer backdrop-blur-md\" data-kid=\"2-6-1-3\" data-name=\"calendar app icon\">\n                <i class=\"ti ti-calendar text-2xl text-white/80\" data-kid=\"2-6-1-3-1\" data-name=\"calendar icon\">\n                </i>\n            </div>\n            <!-- Separator -->\n            <div class=\"w-px h-8 bg-white/10 mx-1 mb-2\" data-kid=\"2-6-1-4\" data-name=\"dock separator\">\n            </div>\n            <div class=\"dock-item w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center border border-white/10 cursor-pointer backdrop-blur-md\" data-kid=\"2-6-1-5\" data-name=\"browser app icon\">\n                <i class=\"ti ti-brand-chrome text-2xl text-white/80\" data-kid=\"2-6-1-5-1\" data-name=\"chrome logo icon\">\n                </i>\n            </div>\n            <div class=\"dock-item w-12 h-12 bg-white/5 rounded-2xl flex items-center justify-center border border-white/10 cursor-pointer backdrop-blur-md\" data-kid=\"2-6-1-6\" data-name=\"terminal app icon\">\n                <i class=\"ti ti-terminal text-2xl text-white/80\" data-kid=\"2-6-1-6-1\" data-name=\"terminal icon\">\n                </i>\n            </div>\n            <!-- Creature AI App -->\n            <div class=\"dock-item w-12 h-12 bg-[var(--color-active)]/10 rounded-2xl flex items-center justify-center border border-[var(--color-active)]/30 cursor-pointer relative shadow-[0_0_15px_rgba(0,255,191,0.2)]\" data-kid=\"2-6-1-7\" data-name=\"creature ai app icon\">\n                <i class=\"ti ti-sparkles text-2xl text-[var(--color-active)]\" data-kid=\"2-6-1-7-1\" data-name=\"sparkles icon\">\n                </i>\n                <div class=\"absolute bottom-[-6px] w-1 h-1 bg-[var(--color-active)] rounded-full shadow-[0_0_4px_var(--color-active)]\" data-kid=\"2-6-1-7-2\" data-name=\"active indicator dot\">\n                </div>\n            </div>\n        </div>\n    </footer>\n    <!-- OS Metadata (Corners) -->\n    <div class=\"absolute bottom-8 left-8 flex flex-col gap-1 pointer-events-none opacity-30\" data-kid=\"2-7\" data-name=\"os info container\">\n        <span class=\"text-[10px] font-bold uppercase tracking-[0.4em]\" data-kid=\"2-7-1\" data-name=\"os name text\">\n            Creature OS\n        </span>\n        <span class=\"text-[9px] font-mono tracking-tighter\" data-kid=\"2-7-2\" data-name=\"os build version text\">\n            EVE_RUNTIME_BUILD_071821\n        </span>\n    </div>\n</div>\n",
